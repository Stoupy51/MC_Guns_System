{
	"type": "minecraft:multi_action",
	"title": {
		"translate": "mgs.quick_reload",
		"color": "gold",
		"bold": true
	},
	"body": [
		{"type": "minecraft:plain_message","contents": {"translate": "mgs.reduce_reload_time_self_only","color": "gray"}}
	],
	"actions": [
		{"label": {"text": "0%","color": "red"},"tooltip": [{"translate":"mgs.set_quick_reload_to"}, " 0%"],"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.quick_reload 0"}},
		{"label": {"text": "20%","color": "yellow"},"tooltip": [{"translate":"mgs.set_quick_reload_to"}, " 20%"],"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.quick_reload 20"}},
		{"label": {"text": "50%","color": "yellow"},"tooltip": [{"translate":"mgs.set_quick_reload_to"}, " 50%"],"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.quick_reload 50"}},
		{"label": {"text": "80%","color": "green"},"tooltip": [{"translate":"mgs.set_quick_reload_to"}, " 80%"],"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.quick_reload 80"}}
	],
	"columns": 1,
	"pause": false,
	"after_action": "none",
	"exit_action": {
		"label": [{"text":"◀ ","color": "gray"}, {"translate": "mgs.back"}],
		"tooltip": {"translate": "mgs.return_to_the_previous_menu"},
		"action": {"type": "show_dialog","dialog": "mgs:config/personal"}
	}
}
