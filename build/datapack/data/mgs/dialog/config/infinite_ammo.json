{
	"type": "minecraft:multi_action",
	"title": {
		"translate": "mgs.infinite_ammo",
		"color": "gold",
		"bold": true
	},
	"body": [
		{"type": "minecraft:plain_message","contents": {"translate": "mgs.no_reloads_needed_for_a_duration_self_only","color": "gray"}}
