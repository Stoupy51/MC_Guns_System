		{"label": {"text": "30s","color": "yellow"},"tooltip": {"translate": "mgs.set_infinite_ammo_for_30s"},"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.infinite_ammo 600"}},
		{"label": {"text": "60s","color": "yellow"},"tooltip": {"translate": "mgs.set_infinite_ammo_for_60s"},"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.infinite_ammo 1200"}},
		{"label": {"text": "∞","color": "light_purple"},"tooltip": [{"translate":"mgs.set_infinite_ammo_for"}, " ∞"],"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.infinite_ammo 72000"}}
