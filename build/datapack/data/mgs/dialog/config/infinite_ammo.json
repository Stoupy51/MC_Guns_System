	"actions": [
		{"label": {"translate": "mgs.off","color": "red"},"tooltip": {"translate": "mgs.set_infinite_ammo_off"},"action": {"type": "run_command","command": "/scoreboard players set @s mgs.special.infinite_ammo 0"}},
